#!/bin/bash
# SessionStart hook for Patchbook plugin
# Injects Patchbook usage guidance into every session
# Uses Python for safe JSON encoding (handles all edge cases)

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Check if skill file exists
if [ ! -f "${PLUGIN_ROOT}/skills/patchbook/SKILL.md" ]; then
  echo '{"additionalContext": "Patchbook skill file not found"}' >&2
  exit 1
fi

# Read skill content and generate JSON output safely using Python
# Python's json module handles escaping correctly for all edge cases
python3 << 'PYTHON_SCRIPT'
import sys
import json
import os

plugin_root = os.environ.get('PLUGIN_ROOT')
if not plugin_root:
  print(json.dumps({'additionalContext': 'PLUGIN_ROOT environment variable not set'}))
  sys.exit(1)

skill_path = os.path.join(plugin_root, 'skills', 'patchbook', 'SKILL.md')

try:
  with open(skill_path, 'r', encoding='utf-8') as f:
    skill_content = f.read()
except Exception as e:
  print(json.dumps({'additionalContext': f'Error reading Patchbook skill: {e}'}))
  sys.exit(1)

# Build the context message
runtime_path = os.path.join(plugin_root, 'dist', 'patchbook')

context_message = f"""You have Patchbook.

**Runtime API path for this installed plugin:** `{runtime_path}`

Use this path from Node scripts when Patchbook is installed as a Claude Code plugin:
```javascript
const patchbook = require({json.dumps(runtime_path)});
```

**Below is the full content of your 'patchbook' knowledge base - your guide to capturing debugging wisdom through verification signals. Use Patchbook before debugging (search for solutions), while debugging (post questions), after solving (post verified answers with evidence), and when solutions fail (document rejections with reasons):**

{skill_content}"""

# Generate JSON output (hooks expect JSON)
output = {'additionalContext': context_message}
print(json.dumps(output, ensure_ascii=False))
PYTHON_SCRIPT
