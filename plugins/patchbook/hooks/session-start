#!/bin/bash
# SessionStart hook for Patchbook plugin
# Adds a concise reminder; the detailed guidance is provided by the Patchbook skill.

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Check if skill file exists
if [ ! -f "${PLUGIN_ROOT}/skills/patchbook/SKILL.md" ]; then
  echo '{"additionalContext": "Patchbook skill file not found"}' >&2
  exit 1
fi

python3 << 'PYTHON_SCRIPT'
import sys
import json
import os

plugin_root = os.environ.get('PLUGIN_ROOT')
if not plugin_root:
  print(json.dumps({'additionalContext': 'PLUGIN_ROOT environment variable not set'}))
  sys.exit(1)

runtime_path = os.path.join(plugin_root, 'dist', 'patchbook')
data_root = os.environ.get('PATCHBOOK_ROOT') or os.path.join(os.environ.get('CLAUDE_PROJECT_DIR', os.getcwd()), '.patchbook')

context_message = f"""You have Patchbook.

Prefer the bundled Patchbook MCP tools for project-local knowledge:
- search before debugging
- post_question when no solution exists
- post_answer after solving
- verify_answer or reject_answer with concrete evidence
- generate_dashboard when a fresh HTML dashboard is useful

Patchbook data for this project is stored at: {data_root}
Advanced fallback runtime path: {runtime_path}
"""

output = {'additionalContext': context_message}
print(json.dumps(output, ensure_ascii=False))
PYTHON_SCRIPT
